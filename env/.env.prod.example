# Production environment for docker compose. Copy to env/.env.prod on the droplet
# and fill in real values — env/.env.prod is git-ignored, never commit it.
# Tip: build it interactively instead with `make docker-env`.
#
#   cp env/.env.prod.example env/.env.prod

# ---- Django ----
SECRET_KEY=GENERATE_ME            # python -c "import secrets; print(secrets.token_urlsafe(64))"
DEBUG=false
# Domain(s) to serve + accept.
# SITE_ADDRESS feeds Caddy (TLS + proxy); Caddy needs each hostname explicitly to
#   fetch its cert, so list every served subdomain here. admin.waygon.dev is a
#   normal entry — it's served at the subdomain root by Django host routing
#   (config/middleware.py + config/urls_admin.py), no special Caddy block needed.
# PROD_HOSTS feeds Django ALLOWED_HOSTS/CSRF and supports a leading-dot wildcard:
#   ".waygon.dev" matches the apex and EVERY subdomain (present + future), so this
#   never needs editing when you add a subdomain. No spaces in PROD_HOSTS.
SITE_ADDRESS=waygon.dev, admin.waygon.dev
PROD_HOSTS=.waygon.dev
WEB_CONCURRENCY=2                 # gunicorn workers
GOOGLE_MAPS_API_KEY=your-google-maps-key

# ---- Postgres (the db service reads POSTGRES_*; Django reads DATABASE_URL — keep them in sync) ----
POSTGRES_DB=waygon_db
POSTGRES_USER=waygon
POSTGRES_PASSWORD=change-me-strong
DATABASE_URL=postgis://waygon:change-me-strong@db:5432/waygon_db   # host "db" = the compose service

# ---- AWS: S3 media storage + SES email ----
# Both activate automatically and independently from the vars below:
#   - S3 media : active as soon as AWS_STORAGE_BUCKET_NAME is set; blank = local filesystem.
#   - SES email: active when the AWS keys are set AND DEBUG=false; otherwise console.
# Leave the bucket blank to keep media on the local Docker volume. Full setup steps
# (IAM user, bucket creation, SES sender verification) are in docs/DEPLOY.md -> AWS.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=waygon-bucket   # globally-unique S3 bucket name; blank = local filesystem
AWS_S3_REGION_NAME=us-east-2      # bucket region; also used as the SES region
DEFAULT_FROM_EMAIL=noreply@waygon.dev   # must be a verified SES sender / domain

# ---- First admin (created on first container boot; FIRST_ADMIN_EMAIL optional) ----
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=change-me-strong
FIRST_ADMIN_EMAIL=admin@example.com

# ---- Firebase (mobile auth) ----
# The mobile API verifies Firebase ID tokens with a service-account key. The key is
# a FILE (git-ignored): `make docker-env` copies it to env/fbsvc.json, and
# docker-compose mounts it into the containers at the path below. Any extra
# Firebase env vars you add during setup are appended here too.
FIREBASE_CREDENTIALS=/app/env/fbsvc.json
