# Local development environment. Copy to env/.env (git-ignored) and fill in.
# Never commit the filled-in copy.
#
#   cp env/.env.dev.example env/.env

# ---- Core ----
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string
GOOGLE_MAPS_API_KEY=your-google-maps-key

# Local Postgres + PostGIS (matches `make dev-db`). The postgis:// scheme keeps
# GeoDjango's database backend.
DATABASE_URL=postgis://admin:changeme@localhost:5432/waygon_db

# ---- AWS (optional in dev — normally leave blank) ----
# With these unset, media is stored on the local filesystem (MEDIA_ROOT) and email
# is printed to the console — no AWS account needed for local work. To exercise S3
# locally, set AWS_STORAGE_BUCKET_NAME (+ the keys). SES email only ever sends when
# DEBUG=false, so locally email stays on the console regardless. See docs/DEPLOY.md.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-2
# DEFAULT_FROM_EMAIL=noreply@waygon.example.com
